# Market Data (get free keys from provider dashboards)
POLYGON_API_KEY=your_polygon_key_here
FINNHUB_API_KEY=your_finnhub_key_here
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# AI — OpenRouter preferred (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-your_key_here
OPENROUTER_MODEL=openrouter/free

# Auth — change in production (long random string)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_HOURS=168

# Database
# Local dev: auto-uses server/data/stocks.db
# Railway: mount volume at /data (auto-uses /data/stocks.db)
# PostgreSQL: DATABASE_URL=postgresql://user:pass@host:5432/vectra
DATABASE_URL=

# Server
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app
CACHE_TTL_SECONDS=60
PORT=8000
