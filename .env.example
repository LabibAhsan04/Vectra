# Market Data
POLYGON_API_KEY=your_polygon_key_here
FINNHUB_API_KEY=your_finnhub_key_here
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here
NEWS_API_KEY=your_newsapi_key_here

# AI (use OpenRouter — preferred — or direct Anthropic)
OPENROUTER_API_KEY=sk-or-your_key_here
OPENROUTER_MODEL=openrouter/free
ANTHROPIC_API_KEY=

# Database
# Local: sqlite in the server working directory
DATABASE_URL=sqlite:///./stocks.db
# Railway (optional persistent volume mounted at /data):
# DATABASE_URL=sqlite:////data/stocks.db

# Server
# Comma-separated browser origins allowed to call the API.
# After deploying the frontend, add your Vercel URL, e.g.:
# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://vectra.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Vercel preview deployments (disable with empty string if undesired)
ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app
CACHE_TTL_SECONDS=60
PORT=8000
